   <item><widget class="QLabel"><property name="text"><string>Helpers</string></property><property name="styleSheet"><string>font-size: 22px; font-weight: bold;</string></property></widget></item>

   <item>
    <widget class="QGroupBox"><property name="title"><string>/etc/hosts Editor</string></property>
